# TeamLens Native Android environment template
# Copy this file to .env for local builds. Do not commit real .env files.

# Hosted production/staging backend
TEAMLENS_API_BASE_URL=https://api.teamlens.co
TEAMLENS_WEB_BASE_URL=https://test.teamlens.co

# Local emulator example:
# TEAMLENS_API_BASE_URL=http://10.0.2.2:5000
# TEAMLENS_WEB_BASE_URL=http://10.0.2.2:3000

# Physical Android phone on same Wi-Fi example:
# TEAMLENS_API_BASE_URL=http://192.168.1.10:5000
# TEAMLENS_WEB_BASE_URL=http://192.168.1.10:3000

# Optional live-view ICE hint for documentation/debug builds.
# Actual production live-view ICE servers are currently provided by backend-ws.
TEAMLENS_WEBRTC_ICE_SERVERS=[{"urls":["stun:stun.l.google.com:19302"]}]
